<UserControl x:Class="WinClonePro.UI.Views.CaptureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:models="clr-namespace:WinClonePro.Core.Models;assembly=WinClonePro.Core"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <ObjectDataProvider x:Key="CompressionValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:CompressionType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <Border Padding="10" Margin="0,0,0,8" Background="#22FFB300" CornerRadius="6"
                        Visibility="{Binding SelectedSourceDisk.IsBootDisk, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Warning: This is your active boot disk. Capture is safe (read-only) but deployment back to this disk is blocked."
                               TextWrapping="Wrap" />
                </Border>
                <DataGrid ItemsSource="{Binding AvailableDisks}"
                          SelectedItem="{Binding SelectedSourceDisk, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBootDisk}" Value="True">
                                    <Setter Property="Background" Value="#33FFB300"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ContainsOS}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                    <Setter Property="Opacity" Value="0.6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding FriendlySize}" Width="120"/>
                        <DataGridTextColumn Header="Drives" Binding="{Binding DriveLettersDisplay}" Width="120"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding MediaType}" Width="120"/>
                        <DataGridTextColumn Header="Health" Binding="{Binding HealthBadge}" Width="120"/>
                        <DataGridTemplateColumn Header="OS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="6,2" CornerRadius="10" Background="#2233CC33"
                                            Visibility="{Binding ContainsOS, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="OS DETECTED" FontWeight="SemiBold" Foreground="#FF1B5E20"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Boot" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,2" Background="#22FFB300" CornerRadius="10"
                                            Visibility="{Binding IsBootDisk, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="BOOT DISK" FontWeight="SemiBold" Foreground="#FF8D6E00"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,16,0,0" Padding="12" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,8,8"
                             materialDesign:HintAssist.Hint="Output path"
                             Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Row="0" Grid.Column="1" Margin="0,0,0,8"
                            Content="Browse"
                            Command="{Binding BrowseOutputPathCommand}" />

                    <TextBox Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                             materialDesign:HintAssist.Hint="Image name"
                             Text="{Binding ImageName, UpdateSourceTrigger=PropertyChanged}" />

                    <ComboBox Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,8"
                              ItemsSource="{Binding Source={StaticResource CompressionValues}}"
                              SelectedItem="{Binding SelectedCompression}" />

                    <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,8"
                              Content="Verify integrity after capture"
                              IsChecked="{Binding VerifyAfterCapture}" />

                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="{Binding EstimatedOutputSize}" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Start Capture"
                        Padding="24,10"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        IsEnabled="{Binding CanCapture}"
                        Command="{Binding StartCaptureCommand}" />
                <Button Content="Cancel"
                        Margin="12,0,0,0"
                        Padding="24,10"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Visibility="{Binding IsCaptureRunning, Converter={StaticResource BoolToVis}}"
                        Command="{Binding CancelCaptureCommand}" />
            </StackPanel>

            <Border Grid.Row="3" Margin="0,16,0,0" Padding="12" Background="{DynamicResource MaterialDesignPaper}" CornerRadius="8"
                    Visibility="{Binding IsCaptureRunning, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <ProgressBar Width="400"
                                     Height="8"
                                     Value="{Binding CaptureProgress}"
                                     Maximum="100" />
                        <ProgressBar Width="80" Height="8" Margin="12,0,0,0" IsIndeterminate="True" />
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" Text="{Binding ProgressMessage}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding EstimatedTimeRemaining}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding CaptureSpeed}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Margin="0,16,0,0" Padding="12" CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#22C8E6C9"/>
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LastResult}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastResult.Success}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="#22C8E6C9"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastResult.Success}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="#22FFCDD2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="{Binding LastResult.Success, StringFormat=Result: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding LastResult.WimPath, StringFormat=WIM: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding LastResult.SizeBytes, StringFormat=SizeBytes: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding LastResult.Duration, StringFormat=Duration: {0}}" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding LastResult.IntegrityCheckPassed, StringFormat=Integrity: {0}}" />
                    <Button Margin="0,8,0,0" Width="120" Content="Open folder" Command="{Binding OpenResultFolderCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

